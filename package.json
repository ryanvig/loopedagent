{
  "name": "loopedagent",
  "version": "1.0.0",
  "description": "Looped autonomous agent infrastructure",
  "main": "dist/server.js",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "commit": "git-cz",
    "validate:railway": "ts-node src/validate_railway.ts",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanvig/loopedagent.git"
  },
  "keywords": [
    "agent",
    "ci-cd",
    "autonomous"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ryanvig/loopedagent/issues"
  },
  "homepage": "https://github.com/ryanvig/loopedagent#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "watchman": false,
    "cacheDirectory": "/tmp/jest_dx",
    "haste": {
      "forceNodeFilesystemAPI": true
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/railway.ts",
      "!src/validate_railway.ts",
      "!src/sentry.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 65,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5"
  },
  "dependencies": {
    "@sentry/node": "^10.20.0",
    "@sentry/tracing": "^7.120.4",
    "convex": "^1.34.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0"
  }
}
